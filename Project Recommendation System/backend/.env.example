PORT=5000

# MongoDB connection (omit to run in mock-data mode)
#MONGO_URI=mongodb://127.0.0.1:27017/projectmatch

# JWT secret — change this before deploying
JWT_SECRET=supersecretkey_change_me

# GitHub Personal Access Token (classic or fine-grained, read-only)
# Without this the app still works via unauthenticated API (60 req/hr limit)
# With it: 5 000 req/hr
#GITHUB_TOKEN=github_pat_...
